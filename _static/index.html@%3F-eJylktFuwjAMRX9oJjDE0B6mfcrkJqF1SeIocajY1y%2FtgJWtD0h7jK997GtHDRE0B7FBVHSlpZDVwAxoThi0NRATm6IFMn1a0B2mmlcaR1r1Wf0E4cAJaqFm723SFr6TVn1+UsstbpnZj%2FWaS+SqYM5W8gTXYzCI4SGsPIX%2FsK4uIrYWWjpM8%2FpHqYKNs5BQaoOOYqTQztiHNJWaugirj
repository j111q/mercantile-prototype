(function(){

	//adds custom callbacks to flexslider config
	if( window.wc_single_product_params && window.wc_single_product_params.flexslider ){
		window.wc_single_product_params.flexslider['start'] = initWcGalleryIndicator;
		window.wc_single_product_params.flexslider['after'] = udpateWcGalleryIndicator;
	}

	function initWcGalleryIndicator( slider ){

		var sliderIndicator = document.createElement('div');

		sliderIndicator.className = 'mercantile-slider-indicator';

		slider[0].appendChild( sliderIndicator )

		//set opacity to 1 ( originally in wc script, but not executed due to custom start.param )
		slider[0].style.opacity = 1;

		//store reference to indicator element
		slider.sliderIndicator = sliderIndicator;

		slider.viewport.resize();
		slider.resize();

		udpateWcGalleryIndicator(slider);
	}

	function udpateWcGalleryIndicator( slider ){

		if( slider.sliderIndicator ) {
			slider.sliderIndicator.innerText = (slider.currentSlide + 1) + '/' + slider.count;
		}
	}

	document.querySelectorAll('.mercantile-product-filter__taxonomy--mobile').forEach( init_product_filter_taxonomy );

	function init_product_filter_taxonomy( taxonomy_heading ){

		taxonomy_heading.addEventListener( 'click', toggleOpen )
	}

	function toggleOpen( ev ){

		var wrapper = ev.currentTarget.closest('.mercantile-product-filter__taxonomy-wrap');

		if(! wrapper){
			return;
		}

		wrapper.classList.toggle('is-open');

	}

	//WC events
	//cart emptied
	jQuery(document.body).on('wc_cart_emptied', function(){
		document.body.classList.add('cart-is-empty');
	})

	jQuery(document.body).on('added_to_cart', function(ev, fragments, hash, $button){
		var product_container = $button[0].closest('li.product');

		if ( ! product_container ) {
			return;
		}

		product_container.classList.add('added_to_cart');

		ev.preventDefault();
	})

	document.addEventListener('keyup', documentKeyUp);

	function documentKeyUp( ev ){

		if( ev.key === 'Escape' ) {
			document.querySelectorAll('.md-size-chart-modal').forEach( function( modal ){ modal.style.display = 'none' } )
		}
	}

	const product_summary = document.querySelector('div.product div.summary');
	const product_availability_wrapper = document.querySelector('.single-product-stock-share-wrapper');

	if( product_summary && product_availability_wrapper ) {

		jQuery('.variations_form', product_summary).each(
			function () {

				jQuery(this).on('found_variation', function( ev, variation){

					var stock = product_availability_wrapper.querySelector('.stock');

					if( stock ){
						stock.remove()
					}

					if( variation && variation.availability_html ){
						var newStock = document.createElement('div');

						newStock.innerHTML = variation.availability_html;

						product_availability_wrapper.prepend(newStock.firstChild)
					}
				});

				jQuery(this).on('hide_variation', function( ev, variation){

					var stock = product_availability_wrapper.querySelector('.stock');

					if(stock){
						stock.hidden = true;
					}
				});

				jQuery(this).on('show_variation', function( ev, variation){

					var stock = product_availability_wrapper.querySelector('.stock');

					if(stock){

						stock.hidden = false;
					}
				});
			}
		);
	}

	// If we are on the product's page and the share buttons are present, add the simple class to the share buttons
	const sharingButton = document.querySelector("body.woocommerce-page[class*=product] .product-info .sharedaddy");
	if ( sharingButton && sharingButton.querySelector('.sharing-anchor') ) {
		sharingButton.querySelector('.sharing-anchor').classList.add('simple');
		sharingButton.classList.add('left-align');
	}

	// Wrap the store notice content inside a span, then move out the dismiss link. This is required to style it better.
	const storeNotice = document.querySelector('.woocommerce-store-notice.demo_store');
	if ( storeNotice ) {
		storeNotice.innerHTML = `<span class="woocommerce-store-notice__content">${storeNotice.innerHTML}</span>`;
		storeNotice.appendChild( storeNotice.querySelector( '.woocommerce-store-notice__dismiss-link' ) );
		storeNotice.innerHTML = `<div class="woocommerce-store-notice__content-wrapper">${storeNotice.innerHTML}</div>`;
	}

